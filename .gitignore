data/Processed/Collisional/*_full.csv

# Benchmark data (regenerated)
benchmarks/tmp/

# ==============================================================================
# Keep These Files (Don't Ignore)
# ==============================================================================

# Force include important files even if they match ignore patterns
!data/Raw/hoang_binh/ba5
!data/Raw/hoang_binh/ba5.f
!data/Processed/Radiative/H_A_E1_LS_n1_15_physical.csv
!data/Processed/Radiative/validation.txt
!README.md
!LICENSE
!docs/*.md
!*.pdf

