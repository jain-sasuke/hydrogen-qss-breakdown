# Create .gitignore
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (don't commit large files)
*.hdf5
*.h5
data/raw/
results/*.npy
results/*.npz

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Temporary
*.log
*.tmp
temp/